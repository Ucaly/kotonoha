---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import '../styles/global.css';
import '../styles/direction-b.css';

interface Props {
  title: string;
  description?: string;
  image?: string | undefined;
  type?: 'website' | 'article';
  publishedDate?: Date;
  jsonLd?: Record<string, unknown>;
}
const {
  title,
  description = 'ことのは — a gentle tech blog',
  image,
  type = 'website',
  publishedDate,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image ? new URL(image, Astro.site).href : undefined;

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Kotonoha',
  description: 'ことのは — a gentle tech blog',
  url: Astro.site?.href,
};
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Kotonoha</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="alternate" type="application/rss+xml" title="Kotonoha" href="/rss.xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Kotonoha" />
    <meta property="og:locale" content="ja_JP" />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? defaultJsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&family=Caveat:wght@500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <SearchModal />
  </body>
</html>
