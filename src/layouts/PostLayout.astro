---
import BaseLayout from "./BaseLayout.astro";
import TagBadge from "../components/TagBadge.astro";
import TOC from "../components/TOC.astro";

interface Props {
  title: string;
  titleEn: string;
  description?: string;
  date: Date;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
  hero?: ImageMetadata;
}

const { title, titleEn, description, date, tags, headings, slug, hero } = Astro.props;

const formattedDate = date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const postDescription = description ?? titleEn;
const canonicalURL = new URL(`/posts/${slug}/`, Astro.site).href;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: postDescription,
  datePublished: date.toISOString(),
  url: canonicalURL,
  mainEntityOfPage: canonicalURL,
  ...(hero && { image: new URL(hero.src, Astro.site).href }),
  author: {
    "@type": "Person",
    name: "Kotonoha",
  },
};
---

<BaseLayout
  title={title}
  description={postDescription}
  type="article"
  publishedDate={date}
  image={hero?.src}
  jsonLd={jsonLd}
>
  <div class="container">
    <div class="post-layout">
      <article>
        <header class="post-header">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <a href="/posts">Posts</a>
          </nav>

          <h1 class="post-title">{title}</h1>
          <p class="post-title-en">{titleEn}</p>

          <div class="post-meta">
            <time datetime={date.toISOString()}>{formattedDate}</time>
            <span aria-hidden="true">·</span>
            <span aria-hidden="true">·</span>
            {tags.map((tag) => <TagBadge tag={tag} />)}
          </div>
        </header>

        <div class="prose" data-pagefind-body>
          <slot />
        </div>
      </article>

      <aside>
        <TOC headings={headings} />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.78rem;
    color: color-mix(in oklab, var(--ink) 50%, transparent);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }
  .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--accent-blue);
  }
  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 0.4rem;
  }
  .post-title-en {
    font-family: "Lora", serif;
    font-style: italic;
    font-size: 1.1rem;
    color: color-mix(in oklab, var(--ink) 60%, transparent);
    margin-bottom: 1rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 0.8rem;
    color: color-mix(in oklab, var(--ink) 55%, transparent);
  }
</style>
