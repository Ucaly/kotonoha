---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostGrid from '../components/PostGrid.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = sorted[0];
const gridPosts = sorted.slice(1, 7);
---
<BaseLayout title="Home" description="ことのは — a gentle Japanese-English tech blog">
  <div class="container">
    <Hero featuredPost={featuredPost} />

    <section class="section">
      <h2 class="section-heading">最新の記事 / Latest Posts</h2>
      <PostGrid posts={gridPosts} />
    </section>
  </div>
</BaseLayout>

<style>
  .section-heading {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: color-mix(in oklab, var(--ink) 60%, transparent);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
</style>
