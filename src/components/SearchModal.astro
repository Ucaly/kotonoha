---
---
<dialog id="search-modal" class="search-modal">
  <div class="search-form">
    <div class="search-input-wrap">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="pagefind-search"
        type="search"
        placeholder="記事を検索 / Search posts..."
        autocomplete="off"
        class="search-input"
      />
      <kbd class="search-esc">Esc</kbd>
    </div>
    <div id="pagefind-results" class="search-results"></div>
  </div>
</dialog>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px);
    border: none;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 4rem 1rem 1rem;
    display: none;
    flex-direction: column;
    align-items: center;
  }
  .search-modal[open] {
    display: flex;
  }
  .search-form {
    width: 100%;
    max-width: 600px;
    background: var(--paper);
    border-radius: 16px;
    box-shadow: var(--shadow-hover);
    overflow: hidden;
  }
  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--rule);
    color: color-mix(in oklab, var(--ink) 50%, transparent);
  }
  .search-input {
    flex: 1;
    border: none;
    background: none;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    color: var(--ink);
    outline: none;
  }
  .search-input::placeholder {
    color: color-mix(in oklab, var(--ink) 40%, transparent);
  }
  .search-esc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    padding: 0.15em 0.4em;
    border: 1px solid var(--rule);
    border-radius: 4px;
    color: color-mix(in oklab, var(--ink) 40%, transparent);
  }
  .search-results {
    padding: 0.5rem;
    max-height: 400px;
    overflow-y: auto;
  }
  :global(.search-result) {
    display: block;
    padding: 0.75rem;
    border-radius: 8px;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink);
  }
  :global(.search-result:hover) {
    background: color-mix(in oklab, var(--accent-blue) 6%, transparent);
    text-decoration: none;
  }
  :global(.search-result__title) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.25rem;
  }
  :global(.search-result__excerpt) {
    font-family: 'Lora', serif;
    font-size: 0.85rem;
    color: color-mix(in oklab, var(--ink) 65%, transparent);
  }
  :global(mark) {
    background: color-mix(in oklab, var(--accent-orange) 25%, transparent);
    color: var(--ink);
    border-radius: 2px;
  }
</style>

<script>
  const modal = document.getElementById('search-modal') as HTMLDialogElement;
  const input = document.getElementById('pagefind-search') as HTMLInputElement;
  const results = document.getElementById('pagefind-results')!;

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });

  // ⌘K / Ctrl+K shortcut
  document.addEventListener('keydown', (e) => {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      modal?.showModal();
      input?.focus();
    }
  });

  // Pagefind search
  let pagefind: any;

  async function runSearch(query: string) {
    if (!query) {
      results.innerHTML = '';
      return;
    }

    if (!pagefind) {
      try {
        // @ts-ignore - loaded at runtime after build
        pagefind = await import('/pagefind/pagefind.js');
      } catch {
        results.innerHTML = '<p style="padding:1rem;font-family:sans-serif;font-size:0.85rem;opacity:0.6;">Search index not available in dev mode. Run npm run build first.</p>';
        return;
      }
    }

    const search = await pagefind.search(query);
    const data = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

    if (data.length === 0) {
      results.innerHTML = '<p style="padding:1rem;font-family:sans-serif;font-size:0.85rem;opacity:0.6;">No results found.</p>';
      return;
    }

    results.innerHTML = data.map(item => `
      <a href="${item.url}" class="search-result">
        <div class="search-result__title">${item.meta?.title ?? 'Post'}</div>
        <div class="search-result__excerpt">${item.excerpt}</div>
      </a>
    `).join('');
  }

  input?.addEventListener('input', (e) => {
    runSearch((e.target as HTMLInputElement).value.trim());
  });
</script>
